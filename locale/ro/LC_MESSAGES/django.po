msgid "Enter search criteria to view patient data. All access is logged for security."
msgstr "Introduceți criteriile de căutare pentru a vedea datele pacientului. Toate accesările sunt înregistrate pentru securitate."

msgid "Showing all assigned patients"
msgstr "Afișează toți pacienții atribuiți"

msgid "Found {{ patients|length }} result(s) for \"<strong>{{ search_query }}</strong>\""
